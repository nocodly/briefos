# BriefOS — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub — it's in .gitignore

# ─── REQUIRED ──────────────────────────────────────────

# OpenAI — for Whisper transcription + AI summaries
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — optional, for users who prefer Claude summaries
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace — for pyannote speaker diarization model download
# Get at: https://huggingface.co/settings/tokens
# Must also accept pyannote model terms at:
# https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGING_FACE_TOKEN=hf_...

# App environment
APP_ENV=development

# ─── OPTIONAL — PRO FEATURES ──────────────────────────

# Supabase — for auth + team sync (Pro plan)
# Get at: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Stripe — Payment Link for Pro plan ($12/mo)
# Create at: https://dashboard.stripe.com → Payment Links
# Format: https://buy.stripe.com/xxxxx
VITE_STRIPE_PRO_LINK=https://buy.stripe.com/...

# ─── NOTES ───────────────────────────────────────────
# OpenAI Whisper cost:   $0.006/min → 30min call ≈ $0.18
# OpenAI GPT-4o cost:    ~$0.03 per meeting summary
# Period report (10 meetings): ~$0.08
# Total per meeting:     ~$0.21
